---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/home.css';

const companies = [
  { name: 'Google', logo: 'https://www.google.com/images/branding/googlelogo/2x/googlelogo_light_color_272x92dp.png' },
  { name: 'Microsoft', logo: 'https://img-prod-cms-rt-microsoft-com.akamaized.net/cms/api/am/imageFileData/RE1Mu3b?ver=5c31' },
  { name: 'Amazon', logo: 'https://upload.wikimedia.org/wikipedia/commons/a/a9/Amazon_logo.svg' },
  { name: 'Netflix', logo: 'https://upload.wikimedia.org/wikipedia/commons/0/08/Netflix_2015_logo.svg' },
  { name: 'Spotify', logo: 'https://storage.googleapis.com/pr-newsroom-wp/1/2018/11/Spotify_Logo_RGB_White.png' },
  { name: 'Airbnb', logo: 'https://upload.wikimedia.org/wikipedia/commons/6/69/Airbnb_Logo_B%C3%A9lo.svg' },
  { name: 'Uber', logo: 'https://upload.wikimedia.org/wikipedia/commons/c/cc/Uber_logo_2018.png' },
  { name: 'Tesla', logo: 'https://upload.wikimedia.org/wikipedia/commons/b/bd/Tesla_Motors.svg' },
];
---

<MainLayout title="QuickQR - Lightning-fast QR Codes">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div style="text-align: center; margin-bottom: 4rem;">
        <div class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span>Lightning-fast QR generation</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-teal">Quick</span>-ly Create
          <span class="block">
            <span class="hero-title-teal">QR</span> Codes
          </span>
        </h1>

        <p class="hero-subtitle">
          Generate QR codes in seconds. Fast and free.
        </p>

        <div class="hero-buttons">
          <a href="/create" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Generate QR Code Now
          </a>
          <a href="/examples" class="btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            View Examples
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- QR Generator Section -->
  <section class="qr-generator-section">
    <div class="qr-generator-container">
      <div class="qr-generator-header">
        <h2 class="qr-generator-title">Create a QR Code <span class="teal">Instantly</span></h2>
        <p class="qr-generator-subtitle">No signup needed. Just type and download.</p>
      </div>

      <div class="qr-generator-card">
        <!-- Type selector -->
        <div class="qr-type-selector">
          <button class="qr-type-btn active" data-type="url">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            URL
          </button>
          <button class="qr-type-btn" data-type="text">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
            Text
          </button>
          <button class="qr-type-btn" data-type="email">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email
          </button>
          <button class="qr-type-btn" data-type="phone">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Phone
          </button>
        </div>

        <div class="qr-generator-body">
          <!-- Input side -->
          <div class="qr-input-side">
            <div class="form-group">
              <label for="qr-content" id="qr-content-label">URL</label>
              <input type="text" id="qr-content" class="qr-content-input" placeholder="https://example.com" autocomplete="off" />
            </div>

            <div class="qr-options">
              <div class="qr-color-option">
                <label for="dots-color">Dots Color</label>
                <div class="qr-color-input">
                  <input type="color" id="dots-color" value="#000000" />
                  <input type="text" id="dots-color-text" value="#000000" />
                </div>
              </div>
              <div class="qr-color-option">
                <label for="bg-color">Background</label>
                <div class="qr-color-input">
                  <input type="color" id="bg-color" value="#ffffff" />
                  <input type="text" id="bg-color-text" value="#ffffff" />
                </div>
              </div>
            </div>

            <button id="download-qr-btn" class="btn-primary qr-download-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download PNG
            </button>
          </div>

          <!-- QR Preview side -->
          <div class="qr-preview-side">
            <div class="qr-preview-wrapper">
              <div id="qr-preview" class="qr-preview"></div>
            </div>
            <p id="qr-hint" class="qr-hint">Start typing to see your QR code</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features">
    <div style="max-width: 80rem; margin: 0 auto; padding: 0 1rem;">
      <div style="text-align: center; margin-bottom: 4rem;">
        <h2 class="features-title">
          Stop Paying For Subscriptions
          <span class="features-title-teal">You Don't Use</span>
        </h2>
        <p class="features-subtitle">
          1,000 free scans monthly. No Contracts. No Commitments.
        </p>
      </div>

      <div class="features-cta">
        <div class="features-cta-box">
          <h3>Try QuickQR for Free</h3>
          <p>Start generating professional QR codes with pay-as-you-go pricing</p>
          <a href="/auth/signup" class="btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Create Your First Code
          </a>
          <p class="features-cta-note">No credit card required - 1,000 free scans monthly</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Marquee -->
  <section class="company-marquee">
    <div class="company-marquee-header">
      <p>Trusted by teams at</p>
    </div>

    <div class="marquee-container">
      <div class="marquee-track">
        {[...companies, ...companies].map((company, idx) => (
          <div class="marquee-item">
            <img src={company.logo} alt={company.name} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Dynamic vs Static Comparison -->
  <section class="comparison">
    <div class="comparison-bg">
      <div class="comparison-bg-blur-1"></div>
      <div class="comparison-bg-blur-2"></div>
    </div>

    <div class="comparison-content">
      <div class="comparison-header">
        <h2 class="comparison-title">Choose Your QR Code Type</h2>
        <p class="comparison-subtitle">Static for simplicity. Dynamic for flexibility.</p>
      </div>

      <div class="comparison-grid">
        <!-- Static Card -->
        <div class="comparison-card">
          <div class="comparison-card-header">
            <h3 class="comparison-card-title">Static</h3>
            <p class="comparison-card-subtitle">Fixed & forever free</p>
          </div>

          <ul class="comparison-list">
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">100% free forever</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">Works offline</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">Perfect for print</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-x" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
              <span class="comparison-list-item-text comparison-list-item-text-muted">Cannot edit after creation</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-x" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
              <span class="comparison-list-item-text comparison-list-item-text-muted">No tracking or analytics</span>
            </li>
          </ul>

          <div class="comparison-card-footer">
            Best for: Business cards, posters, permanent links
          </div>
        </div>

        <!-- Dynamic Card -->
        <div class="comparison-card comparison-card-highlight">
          <div class="comparison-card-header">
            <h3 class="comparison-card-title">Dynamic</h3>
            <p class="comparison-card-subtitle">Smart & trackable</p>
          </div>

          <ul class="comparison-list">
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">Edit destination anytime</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">Full analytics & tracking</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">Location & device data</span>
            </li>
            <li class="comparison-list-item">
              <svg class="comparison-list-item-check" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span class="comparison-list-item-text">A/B testing ready</span>
            </li>
            <li class="comparison-list-item">
              <div style="width: 1.25rem; height: 1.25rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                <div style="width: 0.5rem; height: 0.5rem; border-radius: 9999px; background-color: var(--color-teal-500);"></div>
              </div>
              <span class="comparison-list-item-text">Paid feature</span>
            </li>
          </ul>

          <div class="comparison-card-footer">
            Best for: Campaigns, events, flexible marketing
          </div>
        </div>
      </div>

      <div class="comparison-cta">
        <a href="/create" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Create Your QR Code
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    import { QRCodeStyling } from 'qr-code-styling';

    const contentInput = document.getElementById('qr-content') as HTMLInputElement;
    const dotsColorText = document.getElementById('dots-color-text') as HTMLInputElement;
    const bgColorText = document.getElementById('bg-color-text') as HTMLInputElement;
    const dotsColorPicker = document.getElementById('dots-color') as HTMLInputElement;
    const bgColorPicker = document.getElementById('bg-color') as HTMLInputElement;
    const qrPreview = document.getElementById('qr-preview') as HTMLDivElement;
    const qrHint = document.getElementById('qr-hint') as HTMLParagraphElement;
    const downloadBtn = document.getElementById('download-qr-btn') as HTMLButtonElement;
    const contentLabel = document.getElementById('qr-content-label') as HTMLLabelElement;
    const typeBtns = document.querySelectorAll<HTMLButtonElement>('.qr-type-btn');

    let currentType = 'url';
    let qr: QRCodeStyling | null = null;
    let currentData = '';

    function buildQR(data: string) {
      if (!data) {
        qrPreview.innerHTML = '';
        qrHint.textContent = 'Start typing to see your QR code';
        qrHint.style.display = '';
        return;
      }

      qrHint.style.display = 'none';
      qr = new QRCodeStyling({
        width: 200,
        height: 200,
        data,
        dotsColor: dotsColorText.value,
        bgColor: bgColorText.value,
        dotsType: 'square',
        cornerSquareType: 'square',
        cornerDotType: 'square',
      });
      qr.append(qrPreview);
    }

    function getData(): string {
      const v = contentInput.value.trim();
      if (!v) return '';
      switch (currentType) {
        case 'email': return `mailto:${v}`;
        case 'phone': return `tel:${v}`;
        default: return v;
      }
    }

    typeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        typeBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentType = btn.dataset.type || 'url';

        const labels: Record<string, string> = { url: 'URL', text: 'Text', email: 'Email', phone: 'Phone' };
        const placeholders: Record<string, string> = {
          url: 'https://example.com',
          text: 'Hello, World!',
          email: 'hello@example.com',
          phone: '+1 555 123 4567',
        };
        contentLabel.textContent = labels[currentType] || 'Content';
        contentInput.placeholder = placeholders[currentType] || '';
        contentInput.value = '';
        qrPreview.innerHTML = '';
        qrHint.textContent = 'Start typing to see your QR code';
        qrHint.style.display = '';
      });
    });

    contentInput.addEventListener('input', () => {
      const data = getData();
      currentData = data;
      buildQR(data);
    });

    dotsColorPicker.addEventListener('input', () => {
      dotsColorText.value = dotsColorPicker.value;
      buildQR(currentData);
    });
    dotsColorText.addEventListener('input', () => {
      dotsColorPicker.value = dotsColorText.value;
      buildQR(currentData);
    });
    bgColorPicker.addEventListener('input', () => {
      bgColorText.value = bgColorPicker.value;
      buildQR(currentData);
    });
    bgColorText.addEventListener('input', () => {
      bgColorPicker.value = bgColorText.value;
      buildQR(currentData);
    });

    downloadBtn.addEventListener('click', async () => {
      if (!currentData || !qr) return;
      await qr.download({ name: 'quickqr', extension: 'png' });
    });
  </script>
</MainLayout>
