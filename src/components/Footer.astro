---
interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

// Hidden on redirect pages
const isHidden = currentPath.startsWith('/code/');
---

{!isHidden && (
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        {/* Brand Column */}
        <div class="footer-brand">
          <div class="footer-logo">
            <div class="footer-logo-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
            </div>
            <span class="footer-logo-text">QuickQR</span>
          </div>
          <p class="footer-tagline">Lightning-fast QR code generation for everyone.</p>
        </div>

        {/* Company Column */}
        <div class="footer-section">
          <h4 class="footer-section-title">Company</h4>
          <ul class="footer-links">
            <li><a href="/pricing" class="footer-link">Pricing</a></li>
            <li><span class="footer-link">Blog</span></li>
          </ul>
        </div>

        {/* Legal Column */}
        <div class="footer-section">
          <h4 class="footer-section-title">Legal</h4>
          <ul class="footer-links">
            <li><span class="footer-link">Privacy</span></li>
            <li><span class="footer-link">Terms</span></li>
            <li><span class="footer-link">Security</span></li>
          </ul>
        </div>
      </div>

      {/* Copyright */}
      <div class="footer-bottom">
        <p class="footer-copyright">&copy; 2025 QuickQR. All rights reserved.</p>
        <p class="footer-legal">QR Code is a registered trademark of DENSO WAVE INCORPORATED</p>
      </div>
    </div>
  </footer>
)}
