---
// AuthSidebar.astro — slide-in auth panel
---

<!-- Backdrop -->
<div id="auth-backdrop" class="auth-backdrop"></div>

<!-- Sidebar -->
<div id="auth-sidebar" class="auth-sidebar">
  <div class="auth-sidebar-inner">
    <!-- Close button -->
    <button id="auth-close-btn" class="auth-close-btn" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Header -->
    <div class="auth-sidebar-header">
      <h2 id="auth-sidebar-title">Welcome back</h2>
      <p id="auth-sidebar-subtitle">Sign in to your QuickQR account</p>
    </div>

    <!-- Error message -->
    <div id="auth-error" class="auth-sidebar-error hidden"></div>

    <!-- OAuth buttons -->
    <div class="auth-oauth-buttons">
      <button id="oauth-google-btn" class="oauth-btn oauth-btn-google">
        <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>
      <button id="oauth-github-btn" class="oauth-btn oauth-btn-github">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        Continue with GitHub
      </button>
    </div>

    <!-- Divider -->
    <div class="auth-divider">
      <span>or continue with email</span>
    </div>

    <!-- Email/Password form -->
    <form id="auth-form" class="auth-form">
      <div class="form-group">
        <label for="auth-email">Email</label>
        <input type="email" id="auth-email" name="email" placeholder="you@example.com" required />
      </div>
      <div class="form-group">
        <label for="auth-password">Password</label>
        <input type="password" id="auth-password" name="password" placeholder="Your password" required />
      </div>
      <button type="submit" id="auth-submit-btn" class="auth-submit-btn">Sign In</button>
    </form>

    <!-- Toggle mode -->
    <div class="auth-toggle">
      <span id="auth-toggle-text">Don't have an account?</span>
      <button id="auth-toggle-btn" class="auth-toggle-btn">Sign up</button>
    </div>
  </div>
</div>

<style>
  /* Dark mode sidebar styles */
  .auth-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 998;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .auth-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  .auth-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 420px;
    height: 100vh;
    background: #0f172a; /* Dark slate background */
    z-index: 999;
    visibility: hidden;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.5);
    overflow-y: auto;
    border-left: 1px solid #334155;
  }
  .auth-sidebar.open {
    transform: translateX(0);
    visibility: visible;
  }

  .auth-sidebar-inner {
    padding: 2rem;
    position: relative;
  }

  .auth-close-btn {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #94a3b8;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: background 0.2s, color 0.2s;
  }
  .auth-close-btn:hover {
    background: #1e293b;
    color: #f1f5f9;
  }

  .auth-sidebar-header {
    margin-bottom: 2rem;
    padding-right: 3rem;
  }
  .auth-sidebar-header h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #f8fafc;
    margin-bottom: 0.5rem;
  }
  .auth-sidebar-header p {
    color: #94a3b8;
    font-size: 0.95rem;
  }

  .auth-sidebar-error {
    background: rgba(220, 38, 38, 0.2);
    border: 1px solid rgba(220, 38, 38, 0.4);
    color: #fca5a5;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .auth-oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid #475569;
    background: #1e293b;
    color: #e2e8f0;
  }
  .oauth-btn:hover {
    background: #334155;
    border-color: #64748b;
  }
  .oauth-btn-google:hover {
    border-color: #4285F4;
    background: rgba(66, 133, 244, 0.15);
  }
  .oauth-btn-github:hover {
    border-color: #6b7280;
    background: rgba(107, 114, 128, 0.15);
  }

  .auth-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    color: #64748b;
    font-size: 0.8rem;
  }
  .auth-divider::before,
  .auth-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #475569;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .auth-form .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .auth-form .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e2e8f0;
  }
  .auth-form .form-group input {
    padding: 0.625rem 0.875rem;
    border: 1px solid #475569;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    background: #1e293b;
    color: #f8fafc;
  }
  .auth-form .form-group input:focus {
    border-color: #14b8a6;
    box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.2);
  }
  .auth-form .form-group input::placeholder {
    color: #64748b;
  }

  .auth-submit-btn {
    width: 100%;
    padding: 0.75rem;
    background: #14b8a6;
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .auth-submit-btn:hover {
    background: #0d9488;
  }

  .auth-toggle {
    text-align: center;
    font-size: 0.875rem;
    color: #94a3b8;
  }
  .auth-toggle-btn {
    background: none;
    border: none;
    color: #14b8a6;
    font-weight: 600;
    cursor: pointer;
    margin-left: 0.25rem;
    font-size: 0.875rem;
  }
  .auth-toggle-btn:hover {
    text-decoration: underline;
    color: #2dd4bf;
  }
</style>

<script>
  import { supabase } from '../lib/supabase';

  const sidebar = document.getElementById('auth-sidebar')!;
  const backdrop = document.getElementById('auth-backdrop')!;
  const closeBtn = document.getElementById('auth-close-btn')!;
  const titleEl = document.getElementById('auth-sidebar-title')!;
  const subtitleEl = document.getElementById('auth-sidebar-subtitle')!;
  const errorEl = document.getElementById('auth-error')!;
  const form = document.getElementById('auth-form') as HTMLFormElement;
  const emailInput = document.getElementById('auth-email') as HTMLInputElement;
  const passwordInput = document.getElementById('auth-password') as HTMLInputElement;
  const submitBtn = document.getElementById('auth-submit-btn') as HTMLButtonElement;
  const toggleText = document.getElementById('auth-toggle-text')!;
  const toggleBtn = document.getElementById('auth-toggle-btn')!;

  let mode: 'signin' | 'signup' = 'signin';

  function openSidebar() {
    sidebar.style.visibility = 'visible';
    backdrop.style.visibility = 'visible';
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    setTimeout(() => {
      sidebar.style.visibility = 'hidden';
      backdrop.style.visibility = 'hidden';
    }, 300);
    document.body.style.overflow = '';
  }

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
  }
  function clearError() {
    errorEl.textContent = '';
    errorEl.classList.add('hidden');
  }

  function updateMode() {
    clearError();
    // Toggle mode first before updating UI
    mode = mode === 'signin' ? 'signup' : 'signin';
    
    if (mode === 'signin') {
      titleEl.textContent = 'Welcome back';
      subtitleEl.textContent = 'Sign in to your QuickQR account';
      submitBtn.textContent = 'Sign In';
      toggleText.textContent = "Don't have an account?";
      toggleBtn.textContent = 'Sign up';
    } else {
      titleEl.textContent = 'Create your account';
      subtitleEl.textContent = 'Start generating QR codes today';
      submitBtn.textContent = 'Create Account';
      toggleText.textContent = 'Already have an account?';
      toggleBtn.textContent = 'Sign in';
    }
  }

  // Expose openSidebar globally
  (window as any).openAuthSidebar = openSidebar;

  closeBtn.addEventListener('click', closeSidebar);
  backdrop.addEventListener('click', closeSidebar);
  toggleBtn.addEventListener('click', updateMode);

  // OAuth handlers
  document.getElementById('oauth-google-btn')?.addEventListener('click', async () => {
    if (!supabase) {
      showError('Auth service not configured');
      return;
    }
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.origin + '/dashboard' }
    });
  });

  document.getElementById('oauth-github-btn')?.addEventListener('click', async () => {
    if (!supabase) {
      showError('Auth service not configured');
      return;
    }
    await supabase.auth.signInWithOAuth({
      provider: 'github',
      options: { redirectTo: window.location.origin + '/dashboard' }
    });
  });

  // Email/password form
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearError();
    
    if (!supabase) {
      showError('Auth service not configured. Please try again later.');
      return;
    }
    
    const email = emailInput.value;
    const password = passwordInput.value;
    submitBtn.disabled = true;
    submitBtn.textContent = mode === 'signin' ? 'Signing in...' : 'Creating account...';

    try {
      if (mode === 'signin') {
        const { data, error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        if (data.session) {
          closeSidebar();
          window.location.href = '/dashboard';
        } else {
          throw new Error('No session returned');
        }
      } else {
        const { error } = await supabase.auth.signUp({ email, password });
        if (error) throw error;
        closeSidebar();
        alert('Check your email for a confirmation link!');
      }
    } catch (err: any) {
      showError(err.message || 'Something went wrong');
      submitBtn.disabled = false;
      submitBtn.textContent = mode === 'signin' ? 'Sign In' : 'Create Account';
    }
  });
</script>
