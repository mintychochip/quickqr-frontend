---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/create.css';
---

<MainLayout title="Create QR Code - QuickQR">
  <div class="create-container" id="create-container">
    <!-- Auth check overlay -->
    <div id="auth-check" class="auth-loading-overlay">
      <div class="spinner"></div>
      <p>Checking authentication...</p>
    </div>

    <!-- Create form (hidden until auth check) -->
    <div id="create-content" style="display: none;">
      <div class="create-header">
        <a href="/dashboard" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to Dashboard
        </a>
        <h1>Create QR Code</h1>
      </div>

      <div id="error-message" class="error-message" style="display: none;"></div>
      <div id="success-message" class="success-message" style="display: none;"></div>

      <div class="create-layout">
        <!-- Form Column -->
        <div class="form-column">
          <form class="create-form" id="create-form">
            <!-- Content Type -->
            <div class="form-section">
              <h2>Content Type</h2>
              <div class="type-selector">
                <label class="type-option">
                  <input type="radio" name="type" value="url" checked />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <line x1="2" y1="12" x2="22" y2="12"></line>
                      <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                    </svg>
                    <span>Link</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="email" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                      <polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    <span>Email</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="phone" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                    <span>Phone</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="sms" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    </svg>
                    <span>SMS</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="wifi" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12.55a11 11 0 0 1 14.08 0"></path>
                      <path d="M1.42 9a16 16 0 0 1 21.16 0"></path>
                      <path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path>
                      <line x1="12" y1="20" x2="12.01" y2="20"></line>
                    </svg>
                    <span>WiFi</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="vcard" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                      <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>Contact</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="location" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                      <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                    <span>Location</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="calendar" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="16" y1="2" x2="16" y2="6"></line>
                      <line x1="8" y1="2" x2="8" y2="6"></line>
                      <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    <span>Event</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="crypto" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <line x1="12" y1="6" x2="12" y2="18"></line>
                      <path d="M15 9l-3-3-3 3"></path>
                      <path d="M15 15l-3 3-3-3"></path>
                    </svg>
                    <span>Crypto</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="text" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="4 7 4 4 20 4 20 7"></polyline>
                      <line x1="9" y1="20" x2="15" y2="20"></line>
                      <line x1="12" y1="4" x2="12" y2="20"></line>
                    </svg>
                    <span>Text</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="social" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                    </svg>
                    <span>Social</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="youtube" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
                      <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
                    </svg>
                    <span>YouTube</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="spotify" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"></circle>
                      <path d="M8 12c2.5-1 5.5-1 8 0"></path>
                      <path d="M8 15c3-1.5 5-1.5 8 0"></path>
                      <path d="M8 9c3-1.5 5-1.5 8 0"></path>
                    </svg>
                    <span>Spotify</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="app" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
                      <line x1="12" y1="8" x2="12" y2="8"></line>
                      <line x1="12" y1="16" x2="12" y2="16"></line>
                      <line x1="8" y1="12" x2="8" y2="12"></line>
                      <line x1="16" y1="12" x2="16" y2="12"></line>
                    </svg>
                    <span>App</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="zoom" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 10l4.5-4.5a2.12 2.12 0 0 0 0-3h0a2.12 2.12 0 0 0-3 0L12 7"></path>
                      <path d="M15 14l4.5 4.5a2.12 2.12 0 0 1 0 3h0a2.12 2.12 0 0 1-3 0L12 17"></path>
                      <path d="M9 10L4.5 5.5a2.12 2.12 0 0 1 0-3h0a2.12 2.12 0 0 1 3 0L12 7"></path>
                      <path d="M9 14l-4.5 4.5a2.12 2.12 0 0 0 0 3h0a2.12 2.12 0 0 0 3 0L12 17"></path>
                    </svg>
                    <span>Zoom</span>
                  </span>
                </label>
                <label class="type-option">
                  <input type="radio" name="type" value="pdf" />
                  <span class="type-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                      <path d="M9 13h6"></path>
                      <path d="M9 17h6"></path>
                      <path d="M9 9h1"></path>
                    </svg>
                    <span>PDF</span>
                  </span>
                </label>
              </div>
            </div>

            <!-- Content Fields -->
            <div class="form-section" id="content-section">
              <h2>Content</h2>
              
              <!-- QR Name -->
              <div class="form-group">
                <label for="name">QR Code Name</label>
                <input type="text" id="name" name="name" placeholder="My QR Code" required />
              </div>

              <!-- URL Fields -->
              <div id="url-fields" class="content-fields">
                <div class="form-group">
                  <label for="url">Website URL</label>
                  <input type="url" id="url" name="url" placeholder="https://example.com" />
                </div>
              </div>

              <!-- Email Fields -->
              <div id="email-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="email">Email Address</label>
                  <input type="email" id="email" name="email" placeholder="someone@example.com" />
                </div>
                <div class="form-group">
                  <label for="subject">Subject (optional)</label>
                  <input type="text" id="subject" name="subject" placeholder="Email subject" />
                </div>
                <div class="form-group">
                  <label for="body">Body (optional)</label>
                  <textarea id="body" name="body" rows="3" placeholder="Email body"></textarea>
                </div>
              </div>

              <!-- Phone Fields -->
              <div id="phone-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="phone">Phone Number</label>
                  <input type="tel" id="phone" name="phone" placeholder="+1 (555) 123-4567" />
                </div>
              </div>

              <!-- SMS Fields -->
              <div id="sms-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="smsnumber">Phone Number</label>
                  <input type="tel" id="smsnumber" name="smsnumber" placeholder="+1 (555) 123-4567" />
                </div>
                <div class="form-group">
                  <label for="smsmessage">Message (optional)</label>
                  <textarea id="smsmessage" name="smsmessage" rows="3" placeholder="Pre-filled message..."></textarea>
                </div>
              </div>

              <!-- WiFi Fields -->
              <div id="wifi-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="ssid">Network Name (SSID)</label>
                  <input type="text" id="ssid" name="ssid" placeholder="MyWiFiNetwork" />
                </div>
                <div class="form-group">
                  <label for="password">Password</label>
                  <input type="text" id="wifipassword" name="wifipassword" placeholder="WiFi password" />
                </div>
                <div class="form-group">
                  <label for="encryption">Security</label>
                  <select id="encryption" name="encryption">
                    <option value="WPA">WPA/WPA2</option>
                    <option value="WEP">WEP</option>
                    <option value="nopass">No Password</option>
                  </select>
                </div>
              </div>

              <!-- vCard Fields -->
              <div id="vcard-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="vcardFirstName">First Name</label>
                  <input type="text" id="vcardFirstName" name="vcardFirstName" placeholder="John" />
                </div>
                <div class="form-group">
                  <label for="vcardLastName">Last Name</label>
                  <input type="text" id="vcardLastName" name="vcardLastName" placeholder="Doe" />
                </div>
                <div class="form-group">
                  <label for="vcardPhone">Phone</label>
                  <input type="tel" id="vcardPhone" name="vcardPhone" placeholder="+1 (555) 123-4567" />
                </div>
                <div class="form-group">
                  <label for="vcardEmail">Email</label>
                  <input type="email" id="vcardEmail" name="vcardEmail" placeholder="john@example.com" />
                </div>
                <div class="form-group">
                  <label for="vcardCompany">Company</label>
                  <input type="text" id="vcardCompany" name="vcardCompany" placeholder="Company Name" />
                </div>
                <div class="form-group">
                  <label for="vcardTitle">Job Title</label>
                  <input type="text" id="vcardTitle" name="vcardTitle" placeholder="Software Engineer" />
                </div>
                <div class="form-group">
                  <label for="vcardWebsite">Website</label>
                  <input type="url" id="vcardWebsite" name="vcardWebsite" placeholder="https://example.com" />
                </div>
              </div>

              <!-- Location Fields -->
              <div id="location-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="latitude">Latitude</label>
                  <input type="number" id="latitude" name="latitude" step="any" placeholder="37.7749" />
                </div>
                <div class="form-group">
                  <label for="longitude">Longitude</label>
                  <input type="number" id="longitude" name="longitude" step="any" placeholder="-122.4194" />
                </div>
                <div class="form-group">
                  <label for="locationQuery">Or Search Location</label>
                  <input type="text" id="locationQuery" name="locationQuery" placeholder="San Francisco, CA" />
                </div>
              </div>

              <!-- Calendar Fields -->
              <div id="calendar-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="eventTitle">Event Title</label>
                  <input type="text" id="eventTitle" name="eventTitle" placeholder="Team Meeting" />
                </div>
                <div class="form-group">
                  <label for="eventLocation">Location</label>
                  <input type="text" id="eventLocation" name="eventLocation" placeholder="Conference Room A" />
                </div>
                <div class="form-group">
                  <label for="eventStart">Start Date/Time</label>
                  <input type="datetime-local" id="eventStart" name="eventStart" />
                </div>
                <div class="form-group">
                  <label for="eventEnd">End Date/Time</label>
                  <input type="datetime-local" id="eventEnd" name="eventEnd" />
                </div>
                <div class="form-group">
                  <label for="eventDescription">Description</label>
                  <textarea id="eventDescription" name="eventDescription" rows="3" placeholder="Event details..."></textarea>
                </div>
              </div>

              <!-- Crypto Fields -->
              <div id="crypto-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="cryptoType">Cryptocurrency</label>
                  <select id="cryptoType" name="cryptoType">
                    <option value="bitcoin">Bitcoin (BTC)</option>
                    <option value="ethereum">Ethereum (ETH)</option>
                    <option value="litecoin">Litecoin (LTC)</option>
                    <option value="dogecoin">Dogecoin (DOGE)</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="cryptoAddress">Wallet Address</label>
                  <input type="text" id="cryptoAddress" name="cryptoAddress" placeholder="bc1q..." />
                </div>
                <div class="form-group">
                  <label for="cryptoAmount">Amount (optional)</label>
                  <input type="number" id="cryptoAmount" name="cryptoAmount" step="0.00000001" placeholder="0.001" />
                </div>
              </div>

              <!-- Text Fields -->
              <div id="text-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="textcontent">Text Content</label>
                  <textarea id="textcontent" name="textcontent" rows="4" placeholder="Enter any text..."></textarea>
                </div>
              </div>

              <!-- Social Fields -->
              <div id="social-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="socialPlatform">Platform</label>
                  <select id="socialPlatform" name="socialPlatform">
                    <option value="instagram">Instagram</option>
                    <option value="twitter">Twitter/X</option>
                    <option value="linkedin">LinkedIn</option>
                    <option value="tiktok">TikTok</option>
                    <option value="facebook">Facebook</option>
                    <option value="snapchat">Snapchat</option>
                    <option value="threads">Threads</option>
                    <option value="other">Other</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="socialUrl">Profile URL</label>
                  <input type="url" id="socialUrl" name="socialUrl" placeholder="https://instagram.com/username" />
                </div>
              </div>

              <!-- YouTube Fields -->
              <div id="youtube-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="youtubeUrl">YouTube URL</label>
                  <input type="url" id="youtubeUrl" name="youtubeUrl" placeholder="https://youtube.com/watch?v=..." />
                </div>
              </div>

              <!-- Spotify Fields -->
              <div id="spotify-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="spotifyType">Type</label>
                  <select id="spotifyType" name="spotifyType">
                    <option value="track">Song/Track</option>
                    <option value="album">Album</option>
                    <option value="playlist">Playlist</option>
                    <option value="artist">Artist</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="spotifyUrl">Spotify URL</label>
                  <input type="url" id="spotifyUrl" name="spotifyUrl" placeholder="https://open.spotify.com/track/..." />
                </div>
              </div>

              <!-- App Store Fields -->
              <div id="app-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="appName">App Name</label>
                  <input type="text" id="appName" name="appName" placeholder="My App" />
                </div>
                <div class="form-group">
                  <label for="appStoreUrl">App Store URL (iOS)</label>
                  <input type="url" id="appStoreUrl" name="appStoreUrl" placeholder="https://apps.apple.com/..." />
                </div>
                <div class="form-group">
                  <label for="playStoreUrl">Play Store URL (Android)</label>
                  <input type="url" id="playStoreUrl" name="playStoreUrl" placeholder="https://play.google.com/store/apps/..." />
                </div>
              </div>

              <!-- Zoom Fields -->
              <div id="zoom-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="zoomUrl">Zoom Meeting URL</label>
                  <input type="url" id="zoomUrl" name="zoomUrl" placeholder="https://zoom.us/j/..." />
                </div>
                <div class="form-group">
                  <label for="zoomMeetingId">Meeting ID (optional)</label>
                  <input type="text" id="zoomMeetingId" name="zoomMeetingId" placeholder="123 456 7890" />
                </div>
                <div class="form-group">
                  <label for="zoomPasscode">Passcode (optional)</label>
                  <input type="text" id="zoomPasscode" name="zoomPasscode" placeholder="xxxxxx" />
                </div>
              </div>

              <!-- PDF Fields -->
              <div id="pdf-fields" class="content-fields" style="display: none;">
                <div class="form-group">
                  <label for="pdfUrl">PDF URL</label>
                  <input type="url" id="pdfUrl" name="pdfUrl" placeholder="https://example.com/document.pdf" />
                </div>
                <div class="form-group">
                  <label for="pdfTitle">Title (optional)</label>
                  <input type="text" id="pdfTitle" name="pdfTitle" placeholder="Document Title" />
                </div>
              </div>
            </div>

            <!-- Mode Toggle -->
            <div class="form-section">
              <h2>QR Code Mode</h2>
              <div class="mode-toggle">
                <label class="mode-option">
                  <input type="radio" name="mode" value="static" checked />
                  <span class="mode-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="9" y1="9" x2="15" y2="15"></line>
                      <line x1="15" y1="9" x2="9" y2="15"></line>
                    </svg>
                    <span>
                      <strong>Static</strong>
                      <small>Content is permanent</small>
                    </span>
                  </span>
                </label>
                <label class="mode-option">
                  <input type="radio" name="mode" value="dynamic" />
                  <span class="mode-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/>
                    </svg>
                    <span>
                      <strong>Dynamic</strong>
                      <small>Edit content later, track scans</small>
                    </span>
                  </span>
                </label>
              </div>
            </div>

            <!-- Styling -->
            <div class="form-section">
              <h2>Style</h2>
              
              <div class="style-row">
                <div class="form-group">
                  <label for="dotsColor">Dots Color</label>
                  <div class="color-input">
                    <input type="color" id="dotsColor" name="dotsColor" value="#000000" />
                    <input type="text" id="dotsColorText" value="#000000" />
                  </div>
                </div>
                <div class="form-group">
                  <label for="bgColor">Background</label>
                  <div class="color-input">
                    <input type="color" id="bgColor" name="bgColor" value="#ffffff" />
                    <input type="text" id="bgColorText" value="#ffffff" />
                  </div>
                </div>
              </div>

              <div class="style-row">
                <div class="form-group">
                  <label for="cornerSquareColor">Corner Squares</label>
                  <div class="color-input">
                    <input type="color" id="cornerSquareColor" name="cornerSquareColor" value="#000000" />
                    <input type="text" id="cornerSquareColorText" value="#000000" />
                  </div>
                </div>
                <div class="form-group">
                  <label for="cornerDotColor">Corner Dots</label>
                  <div class="color-input">
                    <input type="color" id="cornerDotColor" name="cornerDotColor" value="#000000" />
                    <input type="text" id="cornerDotColorText" value="#000000" />
                  </div>
                </div>
              </div>

              <div class="style-options">
                <div class="form-group">
                  <label for="dotsType">Dot Style</label>
                  <select id="dotsType" name="dotsType">
                    <option value="square">Square</option>
                    <option value="rounded">Rounded</option>
                    <option value="dots">Dots</option>
                    <option value="classy">Classy</option>
                    <option value="classy-rounded">Classy Rounded</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="cornerSquareType">Corner Square Style</label>
                  <select id="cornerSquareType" name="cornerSquareType">
                    <option value="square">Square</option>
                    <option value="rounded">Rounded</option>
                    <option value="extra-rounded">Extra Rounded</option>
                  </select>
                </div>
                <div class="form-group">
                  <label for="cornerDotType">Corner Dot Style</label>
                  <select id="cornerDotType" name="cornerDotType">
                    <option value="square">Square</option>
                    <option value="rounded">Rounded</option>
                    <option value="extra-rounded">Extra Rounded</option>
                  </select>
                </div>
              </div>
            </div>

            <button type="submit" class="submit-btn" id="submit-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                <polyline points="7 3 7 8 15 8"></polyline>
              </svg>
              Save QR Code
            </button>
          </form>
        </div>

        <!-- Preview Column -->
        <div class="preview-column">
          <div class="preview-card">
            <h3>Preview</h3>
            <div id="qr-preview" class="qr-preview-container">
              <div class="qr-placeholder">
                <p>Enter content to generate preview</p>
              </div>
            </div>
            <div class="preview-actions">
              <button id="download-btn" class="download-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                  <polyline points="7 10 12 15 17 10"></polyline>
                  <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                Download PNG
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from '../config/supabase';
  import QRCodeStyling from 'qr-code-styling';

  let qrCode = null;
  let user = null;

  async function initCreate() {
    const authCheck = document.getElementById('auth-check');
    const createContent = document.getElementById('create-content');
    const errorMessage = document.getElementById('error-message');
    const successMessage = document.getElementById('success-message');
    const createForm = document.getElementById('create-form');
    const submitBtn = document.getElementById('submit-btn');
    const downloadBtn = document.getElementById('download-btn');

    try {
      // Check auth with timeout
      const authPromise = supabase?.auth?.getSession();
      const timeoutPromise = new Promise((_, reject) => 
        setTimeout(() => reject(new Error('Auth check timeout')), 5000)
      );
      
      const { data: { session }, error: sessionError } = await Promise.race([authPromise, timeoutPromise]);
      user = session?.user;

      if (!user || sessionError) {
        // Not authenticated - redirect to homepage
        window.location.href = '/';
        return;
      }

      // Show form
      authCheck.style.display = 'none';
      createContent.style.display = 'block';

      // Initialize QR code
      initQRCode();

      // Type selector handling
      const typeInputs = document.querySelectorAll('input[name="type"]');
      typeInputs.forEach(input => {
        input.addEventListener('change', () => {
          updateContentFields(input.value);
          updateQRPreview();
        });
      });

      // Initial field setup
      updateContentFields('url');

      // Color picker sync
      setupColorPicker('dotsColor', 'dotsColorText');
      setupColorPicker('bgColor', 'bgColorText');
      setupColorPicker('cornerSquareColor', 'cornerSquareColorText');
      setupColorPicker('cornerDotColor', 'cornerDotColorText');

      // Live preview updates
      const previewInputs = createForm.querySelectorAll('input, textarea, select');
      previewInputs.forEach(input => {
        input.addEventListener('input', () => updateQRPreview());
        input.addEventListener('change', () => updateQRPreview());
      });

      // Form submission
      createForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Saving...';
        errorMessage.style.display = 'none';
        successMessage.style.display = 'none';

        const formData = new FormData(createForm);
        const name = formData.get('name')?.toString().trim();
        const type = formData.get('type')?.toString() || 'url';
        const mode = formData.get('mode')?.toString() || 'static';

        if (!name) {
          errorMessage.textContent = 'Please enter a name for your QR code';
          errorMessage.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.innerHTML = getSubmitBtnHTML();
          return;
        }

        // Get content based on type
        const contentObj = getContentByType(type);
        if (!contentObj) {
          errorMessage.textContent = 'Please enter content for your QR code';
          errorMessage.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.innerHTML = getSubmitBtnHTML();
          return;
        }

        // Get styling
        const styling = {
          dotsType: formData.get('dotsType') || 'square',
          dotsColor: formData.get('dotsColor') || '#000000',
          bgColor: formData.get('bgColor') || '#ffffff',
          cornerSquareType: formData.get('cornerSquareType') || 'square',
          cornerSquareColor: formData.get('cornerSquareColor') || '#000000',
          cornerDotType: formData.get('cornerDotType') || 'square',
          cornerDotColor: formData.get('cornerDotColor') || '#000000',
        };

        const { error } = await supabase
          .from('qrcodes')
          .insert({
            user_id: user.id,
            name,
            type,
            content: contentObj,
            styling,
            mode,
            expirytime: null,
          });

        if (error) {
          errorMessage.textContent = error.message;
          errorMessage.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.innerHTML = getSubmitBtnHTML();
        } else {
          successMessage.textContent = 'QR Code created successfully!';
          successMessage.style.display = 'block';
          setTimeout(() => {
            window.location.href = '/dashboard';
          }, 1500);
        }
      });

      // Download button
      downloadBtn?.addEventListener('click', () => {
        qrCode?.download({ name: 'qr-code', extension: 'png' });
      });

    } catch (err: any) {
      console.error('Create page init error:', err);
      authCheck.innerHTML = `<p>Error: ${err.message}</p><button id="create-auth-btn" class="btn-primary" style="margin-top:1rem">Sign In</button>`;
      document.getElementById('create-auth-btn')?.addEventListener('click', () => {
        (window as any).openAuthSidebar?.();
      });
    }
  }

  function initQRCode() {
    qrCode = new QRCodeStyling({
      width: 280,
      height: 280,
      type: 'svg',
      data: 'https://quickqr.app',
      dotsOptions: { color: '#000000', type: 'square' },
      backgroundOptions: { color: '#ffffff' },
      cornersSquareOptions: { color: '#000000', type: 'square' },
      cornersDotOptions: { color: '#000000', type: 'square' },
    });

    const container = document.getElementById('qr-preview');
    if (container) {
      container.innerHTML = '';
      qrCode.append(container);
    }
  }

  function updateContentFields(type) {
    // Hide all field groups
    document.querySelectorAll('.content-fields').forEach(el => {
      el.style.display = 'none';
    });
    // Show selected
    const selectedFields = document.getElementById(`${type}-fields`);
    if (selectedFields) {
      selectedFields.style.display = 'block';
    }
  }

  function setupColorPicker(colorId, textId) {
    const colorInput = document.getElementById(colorId);
    const textInput = document.getElementById(textId);
    
    colorInput?.addEventListener('input', (e) => {
      textInput.value = e.target.value;
      updateQRPreview();
    });
    
    textInput?.addEventListener('input', (e) => {
      if (/^#[0-9a-fA-F]{6}$/.test(e.target.value)) {
        colorInput.value = e.target.value;
        updateQRPreview();
      }
    });
  }

  function getContentByType(type) {
    switch (type) {
      case 'url':
        const url = document.getElementById('url')?.value?.trim();
        return url ? { url } : null;
      
      case 'email':
        const email = document.getElementById('email')?.value?.trim();
        if (!email) return null;
        return { 
          email,
          subject: document.getElementById('subject')?.value || '',
          body: document.getElementById('body')?.value || ''
        };
      
      case 'phone':
        const phone = document.getElementById('phone')?.value?.trim();
        return phone ? { phone } : null;
      
      case 'sms':
        const smsnumber = document.getElementById('smsnumber')?.value?.trim();
        if (!smsnumber) return null;
        return {
          number: smsnumber,
          message: document.getElementById('smsmessage')?.value || ''
        };
      
      case 'wifi':
        const ssid = document.getElementById('ssid')?.value?.trim();
        if (!ssid) return null;
        return {
          ssid,
          password: document.getElementById('wifipassword')?.value || '',
          encryption: document.getElementById('encryption')?.value || 'WPA'
        };
      
      case 'vcard':
        const firstName = document.getElementById('vcardFirstName')?.value?.trim();
        const lastName = document.getElementById('vcardLastName')?.value?.trim();
        if (!firstName && !lastName) return null;
        return {
          firstName,
          lastName,
          phone: document.getElementById('vcardPhone')?.value || '',
          email: document.getElementById('vcardEmail')?.value || '',
          company: document.getElementById('vcardCompany')?.value || '',
          title: document.getElementById('vcardTitle')?.value || '',
          website: document.getElementById('vcardWebsite')?.value || ''
        };
      
      case 'location':
        const lat = document.getElementById('latitude')?.value?.trim();
        const lng = document.getElementById('longitude')?.value?.trim();
        const query = document.getElementById('locationQuery')?.value?.trim();
        if (!lat && !lng && !query) return null;
        return { latitude: lat, longitude: lng, query };
      
      case 'calendar':
        const eventTitle = document.getElementById('eventTitle')?.value?.trim();
        if (!eventTitle) return null;
        return {
          title: eventTitle,
          location: document.getElementById('eventLocation')?.value || '',
          start: document.getElementById('eventStart')?.value || '',
          end: document.getElementById('eventEnd')?.value || '',
          description: document.getElementById('eventDescription')?.value || ''
        };
      
      case 'crypto':
        const cryptoAddress = document.getElementById('cryptoAddress')?.value?.trim();
        if (!cryptoAddress) return null;
        return {
          type: document.getElementById('cryptoType')?.value || 'bitcoin',
          address: cryptoAddress,
          amount: document.getElementById('cryptoAmount')?.value || ''
        };
      
      case 'text':
        const text = document.getElementById('textcontent')?.value?.trim();
        return text ? { text } : null;
      
      case 'social':
        const socialUrl = document.getElementById('socialUrl')?.value?.trim();
        if (!socialUrl) return null;
        return {
          platform: document.getElementById('socialPlatform')?.value || 'other',
          url: socialUrl
        };
      
      case 'youtube':
        const youtubeUrl = document.getElementById('youtubeUrl')?.value?.trim();
        return youtubeUrl ? { url: youtubeUrl } : null;
      
      case 'spotify':
        const spotifyUrl = document.getElementById('spotifyUrl')?.value?.trim();
        if (!spotifyUrl) return null;
        return {
          type: document.getElementById('spotifyType')?.value || 'track',
          url: spotifyUrl
        };
      
      case 'app':
        const appStoreUrl = document.getElementById('appStoreUrl')?.value?.trim();
        const playStoreUrl = document.getElementById('playStoreUrl')?.value?.trim();
        if (!appStoreUrl && !playStoreUrl) return null;
        return {
          name: document.getElementById('appName')?.value || 'My App',
          appStoreUrl,
          playStoreUrl
        };
      
      case 'zoom':
        const zoomUrl = document.getElementById('zoomUrl')?.value?.trim();
        if (!zoomUrl) return null;
        return {
          url: zoomUrl,
          meetingId: document.getElementById('zoomMeetingId')?.value || '',
          passcode: document.getElementById('zoomPasscode')?.value || ''
        };
      
      case 'pdf':
        const pdfUrl = document.getElementById('pdfUrl')?.value?.trim();
        if (!pdfUrl) return null;
        return {
          url: pdfUrl,
          title: document.getElementById('pdfTitle')?.value || 'Document'
        };
      
      default:
        return null;
    }
  }

  function generateQRData(type) {
    const content = getContentByType(type);
    if (!content) return null;

    switch (type) {
      case 'url':
        return content.url;
      
      case 'email':
        const body = content.body ? `&body=${encodeURIComponent(content.body)}` : '';
        const subject = content.subject ? `?subject=${encodeURIComponent(content.subject)}` : '';
        return `mailto:${content.email}${subject}${body}`;
      
      case 'phone':
        return `tel:${content.phone}`;
      
      case 'sms':
        const msg = content.message ? `?body=${encodeURIComponent(content.message)}` : '';
        return `sms:${content.number}${msg}`;
      
      case 'wifi':
        const enc = content.encryption === 'nopass' ? '' : `;P:${content.password}`;
        return `WIFI:S:${content.ssid};T:${content.encryption}${enc};;`;
      
      case 'vcard':
        const name = `${content.firstName || ''} ${content.lastName || ''}`.trim();
        let vcard = 'BEGIN:VCARD\nVERSION:3.0\n';
        vcard += `FN:${name}\n`;
        if (content.phone) vcard += `TEL:${content.phone}\n`;
        if (content.email) vcard += `EMAIL:${content.email}\n`;
        if (content.company) vcard += `ORG:${content.company}\n`;
        if (content.title) vcard += `TITLE:${content.title}\n`;
        if (content.website) vcard += `URL:${content.website}\n`;
        vcard += 'END:VCARD';
        return vcard;
      
      case 'location':
        if (content.latitude && content.longitude) {
          return `geo:${content.latitude},${content.longitude}`;
        } else if (content.query) {
          return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(content.query)}`;
        }
        return null;
      
      case 'calendar':
        const formatDate = (dateStr) => {
          if (!dateStr) return '';
          const date = new Date(dateStr);
          return date.toISOString().replace(/[-:]/g, '').split('.')[0] + 'Z';
        };
        let ics = 'BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\n';
        ics += `SUMMARY:${content.title}\n`;
        if (content.location) ics += `LOCATION:${content.location}\n`;
        if (content.description) ics += `DESCRIPTION:${content.description}\n`;
        if (content.start) ics += `DTSTART:${formatDate(content.start)}\n`;
        if (content.end) ics += `DTEND:${formatDate(content.end)}\n`;
        ics += 'END:VEVENT\nEND:VCALENDAR';
        return ics;
      
      case 'crypto':
        const protocols = { bitcoin: 'bitcoin', ethereum: 'ethereum', litecoin: 'litecoin', dogecoin: 'dogecoin' };
        const protocol = protocols[content.type] || content.type;
        const amount = content.amount ? `?amount=${content.amount}` : '';
        return `${protocol}:${content.address}${amount}`;
      
      case 'text':
        return content.text;
      
      case 'social':
        return content.url;
      
      case 'youtube':
        return content.url;
      
      case 'spotify':
        return content.url;
      
      case 'app':
        // For apps, use a simple landing page URL or the first available store URL
        return content.appStoreUrl || content.playStoreUrl;
      
      case 'zoom':
        return content.url;
      
      case 'pdf':
        return content.url;
      
      default:
        return null;
    }
  }

  function updateQRPreview() {
    if (!qrCode) return;

    const type = document.querySelector('input[name="type"]:checked')?.value || 'url';
    const qrData = generateQRData(type);

    if (qrData) {
      const formData = new FormData(document.getElementById('create-form'));
      
      qrCode.update({
        data: qrData,
        dotsOptions: {
          color: formData.get('dotsColor') || '#000000',
          type: formData.get('dotsType') || 'square'
        },
        backgroundOptions: {
          color: formData.get('bgColor') || '#ffffff'
        },
        cornersSquareOptions: {
          color: formData.get('cornerSquareColor') || '#000000',
          type: formData.get('cornerSquareType') || 'square'
        },
        cornersDotOptions: {
          color: formData.get('cornerDotColor') || '#000000',
          type: formData.get('cornerDotType') || 'square'
        }
      });

      document.getElementById('download-btn').disabled = false;
    }
  }

  function getSubmitBtnHTML() {
    return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg> Save QR Code`;
  }

  initCreate();
</script>

<style>
  .auth-loading-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }
  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(94, 234, 212, 0.2);
    border-top-color: #5eead4;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: #5eead4;
    color: #0f172a;
    border-radius: 0.5rem;
    font-weight: 600;
    text-decoration: none;
  }
</style>