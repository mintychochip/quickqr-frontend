---
import MainLayout from '../layouts/MainLayout.astro';
import { HealthDashboard } from '../components/health/HealthDashboard';
import { NotificationPreferences } from '../components/health/NotificationPreferences';
import { getUser } from '../lib/supabase';

// Check auth using cookies
const user = await getUser(Astro.cookies);

if (!user) {
  return Astro.redirect('/auth/signin');
}

// Get tab from query params
const tab = Astro.url.searchParams.get('tab') || 'dashboard';
const activeTab = ['dashboard', 'settings'].includes(tab) ? tab : 'dashboard';
---

<MainLayout title="Health Dashboard - QuickQR">
  <div class="page-container">
    <div class="max-w-6xl mx-auto px-4 py-6">
      <!-- Tabs -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 mb-6 overflow-hidden">
        <div class="flex border-b border-gray-200">
          <a
            href="/health-dashboard?tab=dashboard"
            class={`tab ${activeTab === 'dashboard' ? 'active' : ''}`}
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Dashboard
          </a>
          <a
            href="/health-dashboard?tab=settings"
            class={`tab ${activeTab === 'settings' ? 'active' : ''}`}
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Notification Settings
          </a>
        </div>
      </div>

      <!-- Content -->
      <div class="content-wrapper">
        {activeTab === 'dashboard' ? (
          <HealthDashboard client:only="react" />
        ) : (
          <NotificationPreferences client:only="react" />
        )}
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .page-container {
    min-height: calc(100vh - 64px);
    background: #f9fafb;
  }

  .tab {
    display: flex;
    align-items: center;
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }

  .tab:hover {
    color: #374151;
    background: #f9fafb;
  }

  .tab.active {
    color: #2563eb;
    border-bottom-color: #2563eb;
    background: #eff6ff;
  }
</style>
