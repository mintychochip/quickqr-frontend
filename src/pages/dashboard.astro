---
import MainLayout from '../layouts/MainLayout.astro';
import DashboardQRList from '../components/DashboardQRList';
import '../styles/dashboard.css';

// Check auth using cookies
const user = await getUser(Astro.cookies);

if (!user) {
  return Astro.redirect('/auth/signin');
}

// Create server client with cookies for data fetching
const supabase = createServerClient(Astro.cookies);

// Fetch user's QR codes
const { data: qrCodes, error } = await supabase
  .from('qrcodes')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(100);

// Fetch analytics data for the last 30 days
const thirtyDaysAgo = new Date();
thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

const { data: scans, error: scansError } = await supabase
  .from('scans')
  .select('os, scanned_at, qrcodes!inner(user_id, name, type)')
  .eq('qrcodes.user_id', user.id)
  .gte('scanned_at', thirtyDaysAgo.toISOString())
  .order('scanned_at', { ascending: false });

// Calculate OS breakdown
const osCounts: Record<string, number> = {};
scans?.forEach(scan => {
  const os = scan.os || 'Unknown';
  osCounts[os] = (osCounts[os] || 0) + 1;
});
const osData = Object.entries(osCounts)
  .map(([os, count]) => ({ os, count, percentage: scans?.length ? (count / scans.length) * 100 : 0 }))
  .sort((a, b) => b.count - a.count);

// Calculate timeline data (last 7 days)
const timelineData: Record<string, number> = {};
for (let i = 6; i >= 0; i--) {
  const d = new Date();
  d.setDate(d.getDate() - i);
  timelineData[d.toISOString().split('T')[0]] = 0;
}
scans?.forEach(scan => {
  const date = scan.scanned_at.split('T')[0];
  if (timelineData.hasOwnProperty(date)) {
    timelineData[date]++;
  }
});

const userEmail = user.email;
const totalScans = qrCodes?.reduce((sum, qr) => sum + (qr.scan_count || 0), 0) || 0;
const recentScans = scans?.length || 0;
---

<MainLayout title="Dashboard - QuickQR">
  <div class="dashboard-container">
    <div class="dashboard-header">
      <div class="header-content">
        <h1>Welcome back</h1>
        <p>{userEmail}</p>
      </div>
      <a href="/create" class="create-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Create QR Code
      </a>
    </div>

    <div class="dashboard-stats">
      <div class="stat-card">
        <div class="stat-value">{qrCodes?.length || 0}</div>
        <div class="stat-label">Total QR Codes</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{totalScans}</div>
        <div class="stat-label">Total Scans</div>
      </div>
      <div class="stat-card highlight">
        <div class="stat-value">{recentScans}</div>
        <div class="stat-label">Last 30 Days</div>
      </div>
      <div class="stat-card">
        <div class="stat-value">{qrCodes?.filter(qr => qr.mode === 'dynamic').length || 0}</div>
        <div class="stat-label">Dynamic Codes</div>
      </div>
    </div>

    {/* Analytics Section */}
    {(recentScans > 0) && (
      <div class="analytics-section">
        <div class="section-header">
          <h2>Analytics Overview</h2>
          <span class="analytics-period">Last 30 days</span>
        </div>

        <div class="analytics-grid">
          {/* Timeline Chart */}
          <div class="analytics-card timeline-card">
            <h3>Scan Activity</h3>
            <div class="timeline-chart">
              {Object.entries(timelineData).map(([date, count]) => {
                const maxCount = Math.max(...Object.values(timelineData), 1);
                const height = maxCount > 0 ? (count / maxCount) * 100 : 0;
                const dayLabel = new Date(date).toLocaleDateString('en-US', { weekday: 'narrow' });
                return (
                  <div class="timeline-bar-container">
                    <div class="timeline-bar" style={`height: ${height}%`} title={`${date}: ${count} scans`}></div>
                    <span class="timeline-label">{dayLabel}</span>
                    {count > 0 && <span class="timeline-count">{count}</span>}
                  </div>
                );
              })}
            </div>
          </div>

          {/* OS Breakdown */}
          {osData.length > 0 && (
            <div class="analytics-card os-card">
              <h3>Devices</h3>
              <div class="os-list">
                {osData.slice(0, 5).map((item) => (
                  <div class="os-item">
                    <div class="os-info">
                      <span class="os-name">{item.os}</span>
                      <span class="os-count">{item.count}</span>
                    </div>
                    <div class="os-bar-container">
                      <div class="os-bar" style={`width: ${item.percentage}%`}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Recent Activity */}
        {scans && scans.length > 0 && (
          <div class="recent-activity">
            <h3>Recent Scans</h3>
            <div class="activity-list">
              {scans.slice(0, 5).map((scan) => (
                <div class="activity-item">
                  <div class="activity-icon">
                    {scan.os === 'iOS' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/>
                        <path d="M10 2c1 .5 2 2 2 5"/>
                      </svg>
                    )}
                    {scan.os === 'Android' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m5 16 13-13"/>
                        <path d="m5 8 9 9"/>
                        <path d="M5 11v5h5"/>
                      </svg>
                    )}
                    {(scan.os !== 'iOS' && scan.os !== 'Android') && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                      </svg>
                    )}
                  </div>
                  <div class="activity-details">
                    <span class="activity-qr">{Array.isArray(scan.qrcodes) ? scan.qrcodes[0]?.name : scan.qrcodes?.name}</span>
                    <span class="activity-meta">{scan.os} • {new Date(scan.scanned_at).toLocaleDateString()}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )}

    <div class="qr-list-section">
      <div class="section-header">
        <h2>Your QR Codes</h2>
      </div>

      {error && (
        <div class="error-message">
          <p>Error loading QR codes: {error.message}</p>
        </div>
      )}

      {!error && (!qrCodes || qrCodes.length === 0) && (
        <div class="empty-state">
          <div class="empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
          </div>
          <a href="/create" class="create-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Create QR Code
          </a>
        </div>

        <div class="dashboard-stats">
          <div class="stat-card">
            <div class="stat-value" id="stat-total">-</div>
            <div class="stat-label">Total QR Codes</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="stat-scans">-</div>
            <div class="stat-label">Total Scans</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="stat-dynamic">-</div>
            <div class="stat-label">Dynamic Codes</div>
          </div>
        </div>

        <div class="qr-list-section">
          <div class="section-header">
            <h2>Your QR Codes</h2>
          </div>
          <div id="qr-list-container">
            <DashboardQRList client:only="react" />
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .analytics-section {
    margin-bottom: 2rem;
  }

  .analytics-period {
    font-size: 0.875rem;
    color: #6b7280;
    background: #f3f4f6;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  .analytics-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .analytics-grid {
      grid-template-columns: 1fr;
    }
  }

  .analytics-card {
    background: white;
    border-radius: 0.75rem;
    padding: 1.25rem;
    border: 1px solid #e5e7eb;
  }

  .analytics-card h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .timeline-chart {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 120px;
    gap: 0.5rem;
    padding-bottom: 1.5rem;
    position: relative;
  }

  .timeline-bar-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    height: 100%;
    justify-content: flex-end;
  }

  .timeline-bar {
    width: 100%;
    background: linear-gradient(to top, #14b8a6, #5eead4);
    border-radius: 0.25rem 0.25rem 0 0;
    min-height: 4px;
    transition: height 0.3s ease;
  }

  .timeline-bar:hover {
    background: #0d9488;
  }

  .timeline-label {
    position: absolute;
    bottom: -1.5rem;
    font-size: 0.75rem;
    color: #6b7280;
  }

  .timeline-count {
    position: absolute;
    top: -1.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #14b8a6;
  }

  .os-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .os-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .os-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
  }

  .os-name {
    color: #374151;
    font-weight: 500;
  }

  .os-count {
    color: #6b7280;
    font-size: 0.75rem;
  }

  .os-bar-container {
    height: 6px;
    background: #f3f4f6;
    border-radius: 9999px;
    overflow: hidden;
  }

  .os-bar {
    height: 100%;
    background: linear-gradient(to right, #14b8a6, #5eead4);
    border-radius: 9999px;
    transition: width 0.3s ease;
  }

  .recent-activity {
    background: white;
    border-radius: 0.75rem;
    padding: 1.25rem;
    border: 1px solid #e5e7eb;
  }

  .recent-activity h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin: 0 0 1rem 0;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .activity-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .activity-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: background 0.15s;
  }

  .activity-item:hover {
    background: #f9fafb;
  }

  .activity-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    border-radius: 0.5rem;
    color: #6b7280;
  }

  .activity-details {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .activity-qr {
    font-size: 0.875rem;
    font-weight: 500;
    color: #111827;
  }

  .activity-meta {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .stat-card.highlight {
    background: linear-gradient(135deg, #14b8a6, #0d9488);
    color: white;
  }

  .stat-card.highlight .stat-label {
    color: rgba(255, 255, 255, 0.8);
  }
</style>
