---
import MainLayout from '../layouts/MainLayout.astro';
import DashboardQRList from '../components/DashboardQRList';
import '../styles/dashboard.css';
---

<MainLayout title="Dashboard - QuickQR">
  <div class="dashboard-container" id="dashboard-container">
    <!-- Auth check overlay -->
    <div id="auth-check" class="auth-loading-overlay">
      <div class="spinner"></div>
      <p>Checking authentication...</p>
    </div>

    <!-- Dashboard content (hidden until auth check) -->
    <div id="dashboard-content" style="display: none;">
      <div class="dashboard-header">
        <div class="header-content">
          <h1>Welcome back</h1>
          <p id="user-email">Loading...</p>
        </div>
        <a href="/create" class="create-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Create QR Code
        </a>
      </div>

      <div class="dashboard-stats">
        <div class="stat-card">
          <div class="stat-value" id="stat-total">-</div>
          <div class="stat-label">Total QR Codes</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="stat-scans">-</div>
          <div class="stat-label">Total Scans</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="stat-dynamic">-</div>
          <div class="stat-label">Dynamic Codes</div>
        </div>
      </div>

      <div class="qr-list-section">
        <div class="section-header">
          <h2>Your QR Codes</h2>
        </div>
        <div id="qr-list-container">
          <DashboardQRList client:only="react" />
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from '../config/supabase';

  async function initDashboard() {
    const authCheck = document.getElementById('auth-check');
    const dashboardContent = document.getElementById('dashboard-content');
    const userEmail = document.getElementById('user-email');

    try {
      const { data: { session }, error: sessionError } = await supabase.auth.getSession();
      const user = session?.user;
      
      if (!user || sessionError) {
        window.location.href = '/';
        return;
      }

      authCheck.style.display = 'none';
      dashboardContent.style.display = 'block';
      userEmail.textContent = user.email || 'Unknown';

    } catch (err) {
      console.error('Dashboard init error:', err);
      authCheck.innerHTML = `<p>Error: ${err.message}</p>`;
    }
  }

  initDashboard();
</script>

<style>
  .auth-loading-overlay {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }
  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(94, 234, 212, 0.2);
    border-top-color: #5eead4;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
