---
import MainLayout from '../layouts/MainLayout.astro';
import DashboardQRList from '../components/DashboardQRList';
import '../styles/dashboard.css';

const user = Astro.locals.user;
---

<MainLayout title="Dashboard - QuickQR">
  <div class="dashboard-container">
    <div class="dashboard-content" style="display: flex; gap: 1.5rem;">
      <!-- Sidebar -->
      <div id="folder-sidebar-root"></div>
      
      <!-- Main Content -->
      <div style="flex: 1; min-width: 0;">
        <div class="dashboard-header">
          <div class="header-content">
            <h1>Welcome back</h1>
            <p>{user?.email || 'Unknown'}</p>
          </div>
          <a href="/create" class="create-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Create QR Code
          </a>
        </div>

        <div class="dashboard-stats">
          <div class="stat-card">
            <div class="stat-value" id="stat-total">-</div>
            <div class="stat-label">Total QR Codes</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="stat-scans">-</div>
            <div class="stat-label">Total Scans</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="stat-dynamic">-</div>
            <div class="stat-label">Dynamic Codes</div>
          </div>
        </div>

        <div class="qr-list-section">
          <div class="section-header">
            <h2>Your QR Codes</h2>
          </div>
          <div id="qr-list-container">
            <DashboardQRList client:only="react" />
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  // Initialize Folder Sidebar
  import('react-dom/client').then(({ createRoot }) => {
    import('../components/folders/FolderSidebar.tsx').then(({ default: FolderSidebar }) => {
      const sidebarRoot = document.getElementById('folder-sidebar-root');
      if (sidebarRoot) {
        const root = createRoot(sidebarRoot);
        
        let selectedFolder = null;
        let selectedTags = [];
        
        const handleFolderSelect = (folderId) => {
          selectedFolder = folderId;
          // Refresh QR list with folder filter
          const qrList = document.getElementById('qr-list-container');
          if (qrList) {
            // Trigger re-render of DashboardQRList with new props
            root.render(FolderSidebar({
              selectedFolder,
              selectedTags,
              onFolderSelect: handleFolderSelect,
              onTagToggle: handleTagToggle,
              onUpdate: handleUpdate
            }));
          }
        };
        
        const handleTagToggle = (tagId) => {
          if (selectedTags.includes(tagId)) {
            selectedTags = selectedTags.filter(id => id !== tagId);
          } else {
            selectedTags = [...selectedTags, tagId];
          }
          handleUpdate();
        };
        
        const handleUpdate = () => {
          // Re-render sidebar
          root.render(FolderSidebar({
            selectedFolder,
            selectedTags,
            onFolderSelect: handleFolderSelect,
            onTagToggle: handleTagToggle,
            onUpdate: handleUpdate
          }));
        };
        
        root.render(FolderSidebar({
          selectedFolder,
          selectedTags,
          onFolderSelect: handleFolderSelect,
          onTagToggle: handleTagToggle,
          onUpdate: handleUpdate
        }));
      }
    });
  });
</script>