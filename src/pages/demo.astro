---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/dashboard.css';
---

<MainLayout title="Dashboard Demo - QuickQR">
  <div class="dashboard-container">
    <div class="dashboard-content">
      <div class="dashboard-header">
        <div class="header-content">
          <h1>Welcome back</h1>
          <p>demo@example.com</p>
        </div>
        <a href="/create" class="create-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Create QR Code
        </a>
      </div>

      <div class="dashboard-stats">
        <div class="stat-card">
          <div class="stat-value">5</div>
          <div class="stat-label">Total QR Codes</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">127</div>
          <div class="stat-label">Total Scans</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">3</div>
          <div class="stat-label">Dynamic Codes</div>
        </div>
      </div>

      <div class="qr-list-section">
        <div class="section-header">
          <h2>Your QR Codes</h2>
        </div>
        <div class="qr-grid-enhanced">
          
          <!-- Card 1: Dynamic URL with analytics expanded -->
          <div class="qr-card-enhanced expanded">
            <div class="qr-card-main">
              <div class="qr-preview-enhanced" style="background: #ffffff">
                <svg viewBox="0 0 80 80" width="80" height="80">
                  <rect fill="white" width="80" height="80"/>
                  <g fill="#14b8a6">
                    <rect x="8" y="8" width="20" height="20"/>
                    <rect x="52" y="8" width="20" height="20"/>
                    <rect x="8" y="52" width="20" height="20"/>
                    <rect x="12" y="12" width="12" height="12" fill="white"/>
                    <rect x="56" y="12" width="12" height="12" fill="white"/>
                    <rect x="12" y="56" width="12" height="12" fill="white"/>
                    <rect x="28" y="8" width="4" height="4"/>
                    <rect x="36" y="8" width="4" height="4"/>
                    <rect x="32" y="12" width="4" height="4"/>
                    <rect x="28" y="16" width="4" height="4"/>
                    <rect x="40" y="16" width="4" height="4"/>
                    <rect x="44" y="20" width="4" height="4"/>
                    <rect x="28" y="28" width="4" height="4"/>
                    <rect x="36" y="28" width="4" height="4"/>
                    <rect x="48" y="28" width="4" height="4"/>
                    <rect x="56" y="28" width="4" height="4"/>
                    <rect x="32" y="32" width="4" height="4"/>
                    <rect x="40" y="32" width="4" height="4"/>
                    <rect x="48" y="36" width="4" height="4"/>
                    <rect x="8" y="40" width="4" height="4"/>
                    <rect x="16" y="40" width="4" height="4"/>
                    <rect x="24" y="40" width="4" height="4"/>
                    <rect x="36" y="44" width="4" height="4"/>
                    <rect x="44" y="44" width="4" height="4"/>
                    <rect x="56" y="44" width="4" height="4"/>
                    <rect x="64" y="44" width="4" height="4"/>
                    <rect x="28" y="52" width="4" height="4"/>
                    <rect x="36" y="52" width="4" height="4"/>
                    <rect x="44" y="52" width="4" height="4"/>
                    <rect x="56" y="56" width="4" height="4"/>
                    <rect x="64" y="56" width="4" height="4"/>
                    <rect x="72" y="56" width="4" height="4"/>
                    <rect x="52" y="64" width="4" height="4"/>
                    <rect x="64" y="64" width="4" height="4"/>
                    <rect x="72" y="64" width="4" height="4"/>
                  </g>
                </svg>
              </div>
              <div class="qr-info-enhanced">
                <h3 class="qr-name">My Website</h3>
                <p class="qr-type">URL</p>
                <p class="qr-scans">42 scans</p>
                <span class="qr-badge dynamic">Dynamic</span>
              </div>
              <div class="qr-actions-enhanced">
                <button class="action-btn analytics active" title="Analytics">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                </button>
                <button class="action-btn edit" title="Edit Content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                </button>
                <button class="action-btn style" title="Edit Style">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
                <a href="#" class="action-btn view" title="View">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </a>
                <button class="action-btn delete" title="Delete">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  </svg>
                </button>
              </div>
            </div>
            
            <!-- Analytics Dropdown -->
            <div class="qr-analytics-dropdown">
              <div class="analytics-header">
                <h4>Analytics</h4>
                <span class="scan-total">42 total scans</span>
              </div>
              <div class="analytics-content">
                <div class="scans-table-container">
                  <table class="scans-table">
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Device</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td>4/6/2026</td>
                        <td>2:15:30 PM</td>
                        <td><span class="device-badge device-ios">iOS</span></td>
                      </tr>
                      <tr>
                        <td>4/6/2026</td>
                        <td>11:42:15 AM</td>
                        <td><span class="device-badge device-android">Android</span></td>
                      </tr>
                      <tr>
                        <td>4/5/2026</td>
                        <td>9:23:47 PM</td>
                        <td><span class="device-badge device-windows">Windows</span></td>
                      </tr>
                      <tr>
                        <td>4/5/2026</td>
                        <td>3:18:22 PM</td>
                        <td><span class="device-badge device-ios">iOS</span></td>
                      </tr>
                      <tr>
                        <td>4/4/2026</td>
                        <td>8:45:10 AM</td>
                        <td><span class="device-badge device-android">Android</span></td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <div class="os-summary">
                  <h5>Summary</h5>
                  <div class="os-pills">
                    <span class="os-pill">iOS: 18</span>
                    <span class="os-pill">Android: 15</span>
                    <span class="os-pill">Windows: 6</span>
                    <span class="os-pill">Other: 3</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Card 2: Static code (no analytics) -->
          <div class="qr-card-enhanced">
            <div class="qr-card-main">
              <div class="qr-preview-enhanced" style="background: #1a1a2e">
                <svg viewBox="0 0 80 80" width="80" height="80">
                  <rect fill="#1a1a2e" width="80" height="80"/>
                  <g fill="#e94560">
                    <rect x="8" y="8" width="20" height="20"/>
                    <rect x="52" y="8" width="20" height="20"/>
                    <rect x="8" y="52" width="20" height="20"/>
                    <rect x="12" y="12" width="12" height="12" fill="#1a1a2e"/>
                    <rect x="56" y="12" width="12" height="12" fill="#1a1a2e"/>
                    <rect x="12" y="56" width="12" height="12" fill="#1a1a2e"/>
                    <rect x="28" y="8" width="4" height="4"/>
                    <rect x="36" y="8" width="4" height="4"/>
                    <rect x="44" y="8" width="4" height="4"/>
                    <rect x="28" y="16" width="4" height="4"/>
                    <rect x="36" y="16" width="4" height="4"/>
                    <rect x="32" y="20" width="4" height="4"/>
                    <rect x="40" y="24" width="4" height="4"/>
                    <rect x="28" y="32" width="4" height="4"/>
                    <rect x="36" y="32" width="4" height="4"/>
                    <rect x="48" y="36" width="4" height="4"/>
                    <rect x="56" y="36" width="4" height="4"/>
                    <rect x="28" y="44" width="4" height="4"/>
                    <rect x="40" y="44" width="4" height="4"/>
                    <rect x="48" y="44" width="4" height="4"/>
                    <rect x="28" y="52" width="4" height="4"/>
                    <rect x="44" y="52" width="4" height="4"/>
                    <rect x="56" y="56" width="4" height="4"/>
                    <rect x="64" y="56" width="4" height="4"/>
                    <rect x="52" y="64" width="4" height="4"/>
                    <rect x="64" y="64" width="4" height="4"/>
                  </g>
                </svg>
              </div>
              <div class="qr-info-enhanced">
                <h3 class="qr-name">WiFi Password</h3>
                <p class="qr-type">WIFI</p>
                <p class="qr-scans static">Static — scans not tracked</p>
              </div>
              <div class="qr-actions-enhanced">
                <button class="action-btn edit" title="Edit Content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                </button>
                <button class="action-btn style" title="Edit Style">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
                <a href="#" class="action-btn view" title="View">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </a>
                <button class="action-btn delete" title="Delete">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Card 3: In edit mode with style tab -->
          <div class="qr-card-enhanced expanded">
            <div class="qr-card-main">
              <div class="qr-preview-enhanced" style="background: #ffffff">
                <svg viewBox="0 0 80 80" width="80" height="80">
                  <rect fill="white" width="80" height="80"/>
                  <g fill="#7c3aed">
                    <rect x="8" y="8" width="20" height="20"/>
                    <rect x="52" y="8" width="20" height="20"/>
                    <rect x="8" y="52" width="20" height="20"/>
                    <rect x="12" y="12" width="12" height="12" fill="white"/>
                    <rect x="56" y="12" width="12" height="12" fill="white"/>
                    <rect x="12" y="56" width="12" height="12" fill="white"/>
                    <rect x="32" y="8" width="4" height="4"/>
                    <rect x="28" y="12" width="4" height="4"/>
                    <rect x="36" y="16" width="4" height="4"/>
                    <rect x="40" y="20" width="4" height="4"/>
                    <rect x="28" y="28" width="4" height="4"/>
                    <rect x="36" y="28" width="4" height="4"/>
                    <rect x="44" y="32" width="4" height="4"/>
                    <rect x="28" y="36" width="4" height="4"/>
                    <rect x="40" y="40" width="4" height="4"/>
                    <rect x="48" y="44" width="4" height="4"/>
                    <rect x="56" y="48" width="4" height="4"/>
                    <rect x="64" y="52" width="4" height="4"/>
                    <rect x="28" y="56" width="4" height="4"/>
                    <rect x="36" y="60" width="4" height="4"/>
                    <rect x="48" y="64" width="4" height="4"/>
                    <rect x="60" y="64" width="4" height="4"/>
                  </g>
                </svg>
              </div>
              <div class="qr-info-enhanced">
                <div class="qr-edit-form">
                  <input type="text" value="Business Card" placeholder="QR Code Name" class="edit-input"/>
                  
                  <div class="edit-tabs">
                    <button class="edit-tab">Content</button>
                    <button class="edit-tab active">Style</button>
                  </div>

                  <div class="style-editor">
                    <div class="style-row">
                      <div class="style-field">
                        <label>Dots Color</label>
                        <div class="color-picker">
                          <input type="color" value="#7c3aed"/>
                          <span>#7c3aed</span>
                        </div>
                      </div>
                      <div class="style-field">
                        <label>Background</label>
                        <div class="color-picker">
                          <input type="color" value="#ffffff"/>
                          <span>#ffffff</span>
                        </div>
                      </div>
                    </div>
                    <div class="style-preview">
                      <svg viewBox="0 0 80 80" width="80" height="80">
                        <rect fill="white" width="80" height="80"/>
                        <g fill="#7c3aed">
                          <rect x="8" y="8" width="20" height="20"/>
                          <rect x="52" y="8" width="20" height="20"/>
                          <rect x="8" y="52" width="20" height="20"/>
                          <rect x="12" y="12" width="12" height="12" fill="white"/>
                          <rect x="56" y="12" width="12" height="12" fill="white"/>
                          <rect x="12" y="56" width="12" height="12" fill="white"/>
                        </g>
                      </svg>
                    </div>
                  </div>
                  
                  <div class="edit-actions">
                    <button class="edit-btn save">Save</button>
                    <button class="edit-btn cancel">Cancel</button>
                  </div>
                </div>
              </div>
              <div class="qr-actions-enhanced">
                <button class="action-btn analytics" title="Analytics">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                </button>
                <button class="action-btn edit" title="Edit Content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                </button>
                <button class="action-btn style active" title="Edit Style">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <circle cx="12" cy="12" r="3"></circle>
                  </svg>
                </button>
                <a href="#" class="action-btn view" title="View">
