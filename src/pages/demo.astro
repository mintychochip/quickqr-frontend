                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Card 4: Email -->
          <div class="qr-card-enhanced">
            <div class="qr-card-main">
              <div class="qr-preview-enhanced" style="background: #0f172a">
                <svg viewBox="0 0 80 80" width="80" height="80">
                  <rect fill="#0f172a" width="80" height="80"/>
                  <g fill="#38bdf8">
                    <rect x="8" y="8" width="20" height="20"/>
                    <rect x="52" y="8" width="20" height="20"/>
                    <rect x="8" y="52" width="20" height="20"/>
                    <rect x="12" y="12" width="12" height="12" fill="#0f172a"/>
                    <rect x="56" y="12" width="12" height="12" fill="#0f172a"/>
                    <rect x="12" y="56" width="12" height="12" fill="#0f172a"/>
                    <rect x="28" y="8" width="4" height="4"/>
                    <rect x="36" y="8" width="4" height="4"/>
                    <rect x="44" y="12" width="4" height="4"/>
                    <rect x="28" y="16" width="4" height="4"/>
                    <rect x="36" y="20" width="4" height="4"/>
                    <rect x="48" y="24" width="4" height="4"/>
                    <rect x="56" y="28" width="4" height="4"/>
                    <rect x="28" y="36" width="4" height="4"/>
                    <rect x="36" y="36" width="4" height="4"/>
                    <rect x="44" y="40" width="4" height="4"/>
                    <rect x="56" y="44" width="4" height="4"/>
                    <rect x="28" y="52" width="4" height="4"/>
                    <rect x="40" y="52" width="4" height="4"/>
                    <rect x="52" y="56" width="4" height="4"/>
                    <rect x="64" y="60" width="4" height="4"/>
                  </g>
                </svg>
              </div>
              <div class="qr-info-enhanced">
                <h3 class="qr-name">Contact Email</h3>
                <p class="qr-type">EMAIL</p>
                <p class="qr-scans">85 scans</p>
                <span class="qr-badge dynamic">Dynamic</span>
              </div>
              <div class="qr-actions-enhanced">
                <button class="action-btn analytics" title="Analytics">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="20" x2="18" y2="10"></line>
                    <line x1="12" y1="20" x2="12" y2="4"></line>
                    <line x1="6" y1="20" x2="6" y2="14"></line>
                  </svg>
                </button>
                <button class="action-btn edit" title="Edit Content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                  </svg>
                </button>
                <button class="action-btn style" title="Edit Style">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
