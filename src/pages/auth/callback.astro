---
import MainLayout from '../../layouts/MainLayout.astro';
import '../../styles/auth.css';
import { createServerClient } from '../../lib/supabase';

// Exchange code for session
const url = Astro.request.url;
const code = new URL(url).searchParams.get('code');
const accessToken = new URL(url).searchParams.get('access_token');
const refreshToken = new URL(url).searchParams.get('refresh_token');

let authError = null;

if (code) {
  // PKCE flow - exchange code for session
  const supabase = createServerClient(Astro.cookies);
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);
  
  if (error) {
    authError = error.message;
  } else if (data.session) {
    // Successfully authenticated, redirect to dashboard
    return Astro.redirect('/dashboard');
  }
} else if (accessToken) {
  // Implicit flow - set session from tokens
  const supabase = createServerClient(Astro.cookies);
  const { data, error } = await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken || '',
  });
  
  if (error) {
    authError = error.message;
  } else if (data.session) {
    // Successfully authenticated, redirect to dashboard
    return Astro.redirect('/dashboard');
  }
}
---

<MainLayout title="Signing In - QuickQR">
  <div class="auth-container">
    <div class="auth-card">
      {authError ? (
        <div class="auth-header">
          <h1>Sign In Error</h1>
          <p style="color: #ef4444;">{authError}</p>
          <a href="/auth/signin" style="color: #14b8a6; margin-top: 1rem; display: inline-block;">Try again</a>
        </div>
      ) : (
        <div class="auth-loading">
          <div class="spinner"></div>
          <p>Signing you in...</p>
        </div>
      )}
    </div>
  </div>
</MainLayout>
