---
import MainLayout from '../../layouts/MainLayout.astro';
import '../../styles/auth.css';
import { createClient } from '../../lib/supabase-ssr';

const code = Astro.url.searchParams.get('code');
const error = Astro.url.searchParams.get('error');
const errorDescription = Astro.url.searchParams.get('error_description');

if (error) {
  // Will be rendered below
} else if (code) {
  const supabase = createClient(Astro);
  const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);

  if (!exchangeError) {
    return Astro.redirect('/dashboard');
  }
}
---

<MainLayout title="Signing In - QuickQR">
  <div class="auth-container">
    <div class="auth-card" id="auth-card">
      {error || Astro.url.searchParams.get('code') ? (
        <div class="auth-header">
          <h1>Sign In Error</h1>
          <p style="color: #ef4444;">
            {error ? `${error}: ${errorDescription}` : 'Failed to exchange auth code. Please try again.'}
          </p>
          <a href="/" style="color: #14b8a6; margin-top: 1rem; display: inline-block;">Try again</a>
        </div>
      ) : (
        <div class="auth-header">
          <h1>No auth parameters</h1>
          <p style="color: #ef4444;">No authentication data found.</p>
          <a href="/" style="color: #14b8a6; margin-top: 1rem; display: inline-block;">Go home</a>
        </div>
      )}
    </div>
  </div>
</MainLayout>
