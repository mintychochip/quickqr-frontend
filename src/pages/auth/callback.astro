---
import MainLayout from '../../layouts/MainLayout.astro';
import '../../styles/auth.css';
---

<MainLayout title="Signing In - QuickQR">
  <div class="auth-container">
    <div class="auth-card" id="auth-card">
      <div class="auth-loading" id="auth-loading">
        <div class="spinner"></div>
        <p>Signing you in...</p>
      </div>
      <div class="auth-header" id="auth-error" style="display: none;">
        <h1>Sign In Error</h1>
        <p id="error-message" style="color: #ef4444;"></p>
        <a href="/" style="color: #14b8a6; margin-top: 1rem; display: inline-block;">Try again</a>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { supabase } from '../../config/supabase';

  async function handleCallback() {
    const loadingEl = document.getElementById('auth-loading');
    const errorEl = document.getElementById('auth-error');
    const errorMsg = document.getElementById('error-message');

    // Get tokens from URL
    const url = new URL(window.location.href);
    const code = url.searchParams.get('code');
    const accessToken = url.searchParams.get('access_token');
    const refreshToken = url.searchParams.get('refresh_token');
    const error = url.searchParams.get('error');
    const errorDescription = url.searchParams.get('error_description');

    if (error) {
      loadingEl.style.display = 'none';
      errorEl.style.display = 'block';
      errorMsg.textContent = `${error}: ${errorDescription}`;
      return;
    }

    if (code) {
      // PKCE flow - exchange code for session
      const { data, error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
      
      if (exchangeError) {
        loadingEl.style.display = 'none';
        errorEl.style.display = 'block';
        errorMsg.textContent = exchangeError.message;
      } else if (data.session) {
        // Success - redirect to dashboard
        window.location.href = '/dashboard';
      }
    } else if (accessToken) {
      // Implicit flow - set session from tokens
      const { data, error: setError } = await supabase.auth.setSession({
        access_token: accessToken,
        refresh_token: refreshToken || '',
      });
      
      if (setError) {
        loadingEl.style.display = 'none';
        errorEl.style.display = 'block';
        errorMsg.textContent = setError.message;
      } else if (data.session) {
        // Success - redirect to dashboard
        window.location.href = '/dashboard';
      }
    } else {
      // No auth params - go home
      window.location.href = '/';
    }
  }

  handleCallback();
</script>