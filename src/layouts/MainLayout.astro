---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import AuthSidebar from '../components/AuthSidebar.astro';
import '../styles/global.css';
import '../styles/navigation.css';
import '../styles/footer.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Lightning-fast QR code generation for everyone.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/quickqr-favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <Navigation />
    <main>
      <slot />
    </main>
    <Footer />
    <AuthSidebar />

    <script>
      // Direct sidebar toggle setup - inline to ensure it works
      (function() {
        const signinBtn = document.getElementById('nav-signin');
        const closeBtn = document.getElementById('close-sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const sidebar = document.getElementById('auth-sidebar');
        
        console.log('[Sidebar Setup] Elements:', { signinBtn: !!signinBtn, sidebar: !!sidebar, closeBtn: !!closeBtn, overlay: !!overlay });

        if (signinBtn && sidebar) {
          signinBtn.addEventListener('click', function(e) {
            console.log('[Sidebar] Sign in button clicked!');
            e.preventDefault();
            e.stopPropagation();
            sidebar.classList.add('open');
            overlay?.classList.add('show');
          });
        }

        if (closeBtn && sidebar) {
          closeBtn.addEventListener('click', function() {
            sidebar.classList.remove('open');
            overlay?.classList.remove('show');
          });
        }

        if (overlay && sidebar) {
          overlay.addEventListener('click', function() {
            sidebar.classList.remove('open');
            overlay.classList.remove('show');
          });
        }
      })();
    </script>
  </body>
</html>
